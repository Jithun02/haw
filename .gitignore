# pyenv
#   For a library or package, you might want to share your .python-version.
#   For an app, this is usually fine to prevent conflicts between different users.
.python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in version control.
#   However, in case of collaboration, if lock is not desired, it can be added to gitignore.
#   Pipfile.lock

# poetry
#   Similar to Pipfile.lock, poetry.lock is generally recommended to be committed.
#   poetry.lock

# pdm
#   Similar to Pipfile.lock, pdm.lock is generally recommended to be committed.
#   pdm.lock

